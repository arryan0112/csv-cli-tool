# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# Required - get yours at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (this is Gemini's most capable fast model)
MODEL=gemini-2.0-flash

# Safety cap - agent stops after this many tool calls in one session
MAX_TURNS=10

# Paths (leave these as default unless you want to move things)
DB_PATH=db/sessions.db
CHROMA_PATH=db/chroma
DATA_DIR=data